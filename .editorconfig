# EditorConfig — applies to all editors that support it (VS Code, IntelliJ, vim, etc.)
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Python
[*.py]
indent_size = 4
max_line_length = 88

# JSON / YAML / TOML — usually kept at 2 spaces by convention
[*.{json,yml,yaml,toml}]
indent_size = 2

# Markdown — don't trim trailing whitespace (two spaces = line break)
[*.md]
trim_trailing_whitespace = false
